# AI provider selection. One active provider is used by /api/chat.
# Allowed values: gemini, openai, anthropic
AI_PROVIDER="gemini"

# Provider keys stay server-side. Configure only the providers you want to use.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENAI_API_KEY="MY_OPENAI_API_KEY"
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# Optional model overrides
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_MODEL="claude-3-5-haiku-latest"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
